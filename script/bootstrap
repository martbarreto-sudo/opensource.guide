#!/bin/bash

set -e

cd "$(dirname "$0")/.."

if [[ -z "${SKIP_BUNDLER}" ]]; then
  echo "==> Installing gem dependencies…"
  # Bundler removed the --path and --binstubs install flags; configure them
  # explicitly so bootstrap works across Bundler versions and stays
  # environment-agnostic. A failed install now aborts (set -e) instead of
  # being swallowed by a short-circuit, so callers never get a false success.
  bundle config set --local path vendor/gems
  if ! bundle check &>/dev/null; then
    time bundle install
    bundle binstubs --all --force
  fi
fi

echo "==> Installing node dependencies…"
npm install
